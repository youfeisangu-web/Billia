# データベース接続 (Supabase)
# Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Clerk (ログイン機能)
# https://dashboard.clerk.com > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk URL設定
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase Storage用
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# Gemini API（メモ解析・入金消込・OCR用）
# 発行・再発行: https://aistudio.google.com/apikey （期限切れ時はここで再発行し .env を更新）
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash  # 省略可（デフォルト: gemini-2.5-flash）

# リリース通知ウエイトリスト（Google Apps Script Web App の URL）
# 未設定の場合はフォーム送信時にスプレッドシートへ送信されません（docs/WAITLIST_GOOGLE_SHEET.md 参照）
NEXT_PUBLIC_WAITLIST_WEBHOOK_URL=https://script.google.com/macros/s/xxxx/exec
